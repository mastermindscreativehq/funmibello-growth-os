// FUNMI BELLO Growth OS — Prisma Schema
// Database: Supabase / PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Platform {
  INSTAGRAM
  TIKTOK
  TWITTER
  FACEBOOK
  WHATSAPP
  TELEGRAM
  MANUAL
}

enum LeadStatus {
  NEW
  QUALIFIED
  CONTACTED
  INTERESTED
  CONVERTED
  LOST
}

enum IntentLevel {
  LOW
  MEDIUM
  HIGH
  HOT
}

enum InterestCategory {
  BESPOKE
  READY_TO_WEARE
  READY_TO_WEAR
  CAPS
  ACCESSORIES
  URBAN_FASHION
  LUXURY_NATIVE
  CASUAL_WEAR
  UNKNOWN
}

enum RecommendationType {
  CONTENT
  LEAD
  PRODUCT
  COMPETITOR
  SALES
  BRAND_POSITIONING
}

enum RecommendationStatus {
  PENDING
  ACTIONED
  DISMISSED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Lead {
  id               String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  fullName         String?
  username         String?
  platform         Platform?
  platformUserId   String?
  phone            String?
  email            String?
  location         String?
  gender           String?
  source           String?
  interestCategory InterestCategory? @default(UNKNOWN)
  stylePreference  String?
  budgetRange      String?
  intentLevel      IntentLevel?      @default(LOW)
  leadScore        Int?              @default(0)
  status           LeadStatus?       @default(NEW)
  lastContactedAt  DateTime?         @db.Timestamptz(6)
  notes            String?
  createdAt        DateTime?         @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime?         @default(now()) @updatedAt @db.Timestamptz(6)

  comments         SocialComment[]
  outreachMessages OutreachMessage[]

  @@map("leads")
}

model SocialComment {
  id              String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  platform        Platform
  postUrl         String?
  postId          String?
  commentId       String?
  username        String?
  displayName     String?
  profileUrl      String?
  commentText     String
  likeCount       Int?              @default(0)
  publishedAt     DateTime?         @db.Timestamptz(6)
  rawPayload      Json?
  processed       Boolean?          @default(false)
  classification  String?
  sentiment       String?
  buyingIntent    IntentLevel?
  fashionInterest InterestCategory?
  detectedNeed    String?
  suggestedReply  String?
  leadId          String?
  createdAt       DateTime?         @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime?         @default(now()) @updatedAt @db.Timestamptz(6)
  lead            Lead?             @relation(fields: [leadId], references: [id], onUpdate: NoAction)

  @@map("social_comments")
}

model Competitor {
  id              String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  brandName       String
  instagramHandle String?
  tiktokHandle    String?
  location        String?
  niche           String?
  notes           String?
  createdAt       DateTime?          @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime?          @default(now()) @updatedAt @db.Timestamptz(6)

  signals         CompetitorSignal[]

  @@map("competitors")
}

model CompetitorSignal {
  id              String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  competitorId    String
  platform        Platform
  postUrl         String?
  caption         String?
  engagementCount Int?       @default(0)
  commentCount    Int?       @default(0)
  likeCount       Int?       @default(0)
  signalType      String?
  insight         String?
  createdAt       DateTime?  @default(now()) @db.Timestamptz(6)
  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("competitor_signals")
}

model Recommendation {
  id          String                @id @default(dbgenerated("(gen_random_uuid())::text"))
  type        RecommendationType
  title       String
  description String
  priority    Int?                  @default(1)
  source      String?
  status      RecommendationStatus? @default(PENDING)
  createdAt   DateTime?             @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime?             @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("recommendations")
}

model OutreachMessage {
  id        String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  leadId    String?   @map("lead_id")
  platform  String?   @default("INSTAGRAM")
  username  String?
  message   String
  status    String?   @default("PENDING")
  createdAt DateTime? @default(now()) @db.Timestamptz(6) @map("created_at")
  sentAt    DateTime? @db.Timestamptz(6) @map("sent_at")
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("outreach_messages")
}

model OutreachTemplate {
  id               String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  intentLevel      String    @map("intent_level")
  interestCategory String?   @map("interest_category")
  template         String
  isActive         Boolean?  @default(true) @map("is_active")
  createdAt        DateTime? @default(now()) @db.Timestamptz(6) @map("created_at")

  @@map("outreach_templates")
}

model ContentIdea {
  id        String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  idea      String
  brand     String?
  niche     String?
  audience  String?
  goal      String?
  createdAt DateTime? @default(now()) @db.Timestamptz(6)

  @@map("content_ideas")
}
