# ─────────────────────────────────────────────────────────────────
# FUNMI BELLO Growth OS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env to Git.
# ─────────────────────────────────────────────────────────────────

# Supabase PostgreSQL connection string
# Found in: Supabase → Settings → Database → Connection String → URI (use the direct connection, not the pooler)
# Replace [YOUR-PASSWORD] and [YOUR-PROJECT-REF] with your actual values.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Server
PORT=4000
NODE_ENV=development

# CORS — Frontend origin (update when dashboard is built)
CORS_ORIGIN=http://localhost:5173
